@page "/"
@using Application.DTOs
@using Application.Interfaces.RestEase
@using UI.Models
@inject IConfigApi ConfigApi
@inject IRealtimeApi RealtimeApi
@inject DialogService DialogService
@implements IDisposable

<PageTitle>Realtime temperature</PageTitle>

<RadzenStack Gap="1rem" Style="width: 100%;">
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
        <RadzenText TextStyle="TextStyle.H4">Real-time temperature</RadzenText>
        <RadzenBadge BadgeStyle="BadgeStyle.Primary" Text="@($"Reload: {_reloadSeconds} s")" />
    </RadzenStack>

    @if (_config != null && _config.ReloadIntervalSeconds.HasValue)
    {
        <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" Variant="Variant.Outlined">
            Updates every <strong>@(_config.ReloadIntervalSeconds) seconds</strong>. Measure time: <strong>@_lastMeasureTime</strong>
        </RadzenAlert>
    }

    @if (_loading && _realtimeData == null)
    {
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else if (_publishedLocations?.Any() == true)
    {
        <div class="realtime-cards-row">
            @foreach (var loc in _publishedLocations)
            {
                var temp = GetTemperatureForLocation(loc.Id);
                <RadzenCard class="realtime-card card-clickable" @onclick="() => OpenChart(loc)">
                    <RadzenStack Gap="0.5rem">
                        <RadzenText TextStyle="TextStyle.Subtitle1" Style="font-weight: bold;">@loc.Name</RadzenText>
                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.25rem">
                            <RadzenText TextStyle="TextStyle.H3" class="temperature-value">@(temp?.ToString("F1") ?? "—")</RadzenText>
                            <RadzenText TextStyle="TextStyle.H6" class="temperature-unit">°C</RadzenText>
                        </RadzenStack>
                    </RadzenStack>
                </RadzenCard>
            }
        </div>
    }
    else
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning" Variant="Variant.Outlined">
            No locations are published. Go to <RadzenLink Path="/config" Text="Settings" /> to add and publish.
        </RadzenAlert>
    }
</RadzenStack>

@code {
    private RevoConfigDto? _config;
    private RealtimeDataDto? _realtimeData;
    private List<LocationConfigItemDto>? _publishedLocations;
    private readonly Dictionary<Guid, List<TemperatureChartPoint>> _temperatureHistory = new();
    private bool _loading = true;
    private int _reloadSeconds = 10;
    private string _lastMeasureTime = "—";
    private CancellationTokenSource? _timerCts;

    protected override async Task OnInitializedAsync()
    {
        await LoadConfigAsync();
        await LoadRealtimeAsync();
        _ = RunTimerLoopAsync();
    }

    private async Task LoadConfigAsync()
    {
        _config = await ConfigApi.GetActiveAsync();
        _publishedLocations = _config?.Locations?.Where(x => x.Publish).ToList() ?? new List<LocationConfigItemDto>();
        if (_config?.ReloadIntervalSeconds != null)
            _reloadSeconds = _config.ReloadIntervalSeconds.Value;
    }

    private async Task LoadRealtimeAsync()
    {
        _loading = true;
        try
        {
            _realtimeData = await RealtimeApi.GetFirstOrDefaultAsync();
            if (_realtimeData?.CreatedAt != null)
                _lastMeasureTime = _realtimeData.CreatedAt.Value.ToLocalTime().ToString("HH:mm:ss dd/MM/yyyy");

            foreach (var loc in _publishedLocations ?? Enumerable.Empty<LocationConfigItemDto>())
            {
                var temp = _realtimeData?.Temperatures?.FirstOrDefault(t => t.LocationId == loc.Id)?.Temperature;
                if (temp == null) continue;
                if (!_temperatureHistory.ContainsKey(loc.Id))
                    _temperatureHistory[loc.Id] = new List<TemperatureChartPoint>();
                var list = _temperatureHistory[loc.Id];
                var intervalSeconds = Math.Max(1, _reloadSeconds);
                var time = list.Count == 0
                    ? DateTime.UtcNow
                    : list[list.Count - 1].Time.AddSeconds(intervalSeconds);
                list.Add(new TemperatureChartPoint { Time = time, Value = temp.Value });
                const int maxPoints = 20;
                if (list.Count > maxPoints)
                    list.RemoveRange(0, list.Count - maxPoints);
            }
        }
        finally
        {
            _loading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunTimerLoopAsync()
    {
        _timerCts = new CancellationTokenSource();
        var token = _timerCts.Token;
        while (!token.IsCancellationRequested)
        {
            await Task.Delay(Math.Max(5000, _reloadSeconds * 1000), token);
            if (token.IsCancellationRequested) break;
            await LoadConfigAsync();
            await LoadRealtimeAsync();
        }
    }

    private double? GetTemperatureForLocation(Guid locationId)
    {
        return _realtimeData?.Temperatures?.FirstOrDefault(t => t.LocationId == locationId)?.Temperature;
    }

    private async Task OpenChart(LocationConfigItemDto loc)
    {
        var points = _temperatureHistory.TryGetValue(loc.Id, out var list) ? new List<TemperatureChartPoint>(list) : new List<TemperatureChartPoint>();
        var parameters = new Dictionary<string, object>
        {
            [nameof(TemperatureChartDialog.Title)] = loc.Name,
            [nameof(TemperatureChartDialog.DataPoints)] = points,
            [nameof(TemperatureChartDialog.LocationId)] = loc.Id,
            [nameof(TemperatureChartDialog.GetDataForLocation)] = (Func<Guid, List<TemperatureChartPoint>>)(id => _temperatureHistory.TryGetValue(id, out var l) ? new List<TemperatureChartPoint>(l) : new List<TemperatureChartPoint>())
        };
        await DialogService.OpenAsync<TemperatureChartDialog>($"{loc.Name} — Temperature over time", parameters, new DialogOptions { Width = "90vw", Height = "100%", CloseDialogOnOverlayClick = true });
    }

    public void Dispose()
    {
        _timerCts?.Cancel();
        _timerCts?.Dispose();
    }
}
