@page "/config"
@using Application.DTOs
@using Application.Interfaces.RestEase
@inject IConfigApi ConfigApi
@inject NotificationService NotificationService

<PageTitle>Settings</PageTitle>

<RadzenStack Gap="1rem" Style="width: 100%;">
    <RadzenText TextStyle="TextStyle.H4" Style="margin-bottom: 1rem;">Settings</RadzenText>

    @if (_loading)
    {
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else if (_config != null)
    {
        <RadzenCard>
            <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin-bottom: 0.75rem;">Reload interval (seconds)</RadzenText>
            <RadzenNumeric @bind-Value="_reloadSeconds" Min="5" Max="120" Style="max-width: 120px" />
            <RadzenText TextStyle="TextStyle.Caption" Style="margin-top: 0.25rem;">The Realtime page will auto-update after this many seconds.</RadzenText>
        </RadzenCard>

        <RadzenCard>
            <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin-bottom: 0.75rem;">Temperature measurement locations</RadzenText>
            <RadzenDataGrid Data="@(_config.Locations ?? new List<LocationConfigItemDto>())" TItem="LocationConfigItemDto" AllowFiltering="false" AllowPaging="false" AllowSorting="false" Style="margin-bottom: 1rem;">
                <Columns>
                    <RadzenDataGridColumn TItem="LocationConfigItemDto" Property="Name" Title="Location name" />
                    <RadzenDataGridColumn TItem="LocationConfigItemDto" Property="Path" Title="Path" Width="220px">
                        <Template Context="ctx">
                            <RadzenTextBox @bind-Value="ctx.Path" Placeholder="e.g. /api/sensor/1" Style="width: 100%;" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="LocationConfigItemDto" Property="Publish" Title="Publish" Width="100px">
                        <Template Context="ctx">
                            <RadzenSwitch @bind-Value="ctx.Publish" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="LocationConfigItemDto" Title="Actions" Width="80px" Sortable="false" Filterable="false">
                        <Template Context="ctx">
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => RemoveLocation(ctx))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </RadzenDataGrid>

            <RadzenStack Gap="0.25rem" Style="margin-bottom: 0.5rem;">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem" AlignItems="AlignItems.Center">
                    <RadzenStack Gap="0.15rem">
                        <RadzenTextBox @bind-Value="_newLocationName"
                                       @oninput="() => _nameError = false"
                                       Placeholder="Location name *"
                                       Style="@($"max-width: 200px; border-color: {(_nameError ? "var(--rz-danger)" : "")}")" />
                        @if (_nameError)
                        {
                            <RadzenText Style="color: var(--rz-danger); font-size: 0.75rem;">Name is required</RadzenText>
                        }
                    </RadzenStack>
                    <RadzenTextBox @bind-Value="_newLocationPath" Placeholder="Path (optional)" Style="max-width: 200px" />
                    <RadzenButton Text="Add" ButtonStyle="ButtonStyle.Primary" Icon="add" Click="AddLocation" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        <RadzenButton Text="Save settings" ButtonStyle="ButtonStyle.Primary" Icon="save" Size="ButtonSize.Large" Click="Save" />
    }
    else
    {
        <RadzenAlert AlertStyle="AlertStyle.Warning">No settings yet. Create new settings.</RadzenAlert>
        <RadzenCard>
            <RadzenNumeric @bind-Value="_reloadSeconds" Label="Reload interval (seconds)" Min="5" Max="120" Style="margin-bottom: 1rem;" />
            <RadzenButton Text="Create new settings" ButtonStyle="ButtonStyle.Primary" Icon="add" Click="CreateAndSave" />
        </RadzenCard>
    }
</RadzenStack>

@code {
    private RevoConfigDto? _config;
    private bool _loading = true;
    private int _reloadSeconds = 10;
    private bool _nameError = false;
    private string _newLocationName = "";
    private string _newLocationPath = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _config = await ConfigApi.GetActiveAsync();
            if (_config != null)
                _reloadSeconds = _config.ReloadIntervalSeconds ?? 10;
            else
                _config = new RevoConfigDto { Locations = new List<LocationConfigItemDto>() };
        }
        finally
        {
            _loading = false;
        }
    }

    private void AddLocation()
    {
        if (string.IsNullOrWhiteSpace(_newLocationName))
        {
            _nameError = true;
            return;
        }
        _nameError = false;
        _config ??= new RevoConfigDto { Locations = new List<LocationConfigItemDto>() };
        var list = new List<LocationConfigItemDto>(_config.Locations ?? new List<LocationConfigItemDto>())
        {
            new LocationConfigItemDto
            {
                Id = Guid.NewGuid(),
                Name = _newLocationName.Trim(),
                Path = _newLocationPath?.Trim() ?? "",
                Publish = true
            }
        };
        _config.Locations = list;
        _newLocationName = "";
        _newLocationPath = "";
    }

    private void RemoveLocation(LocationConfigItemDto item)
    {
        if (_config?.Locations == null) return;
        var list = new List<LocationConfigItemDto>(_config.Locations);
        list.Remove(item);
        _config.Locations = list;
    }

    private async Task Save()
    {
        if (_config == null) return;
        _config.ReloadIntervalSeconds = _reloadSeconds;
        try
        {
            if (_config.Id == Guid.Empty)
                await ConfigApi.CreateAsync(_config);
            else
                await ConfigApi.UpdateAsync(_config.Id, _config);
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Settings saved." });
            await LoadAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = ex.Message });
        }
    }

    private async Task CreateAndSave()
    {
        _config = new RevoConfigDto
        {
            Id = Guid.Empty,
            ReloadIntervalSeconds = _reloadSeconds,
            Actived = true,
            Locations = new List<LocationConfigItemDto>()
        };
        try
        {
            await ConfigApi.CreateAsync(_config);
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Settings created." });
            await LoadAsync();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = "Error", Detail = ex.Message });
        }
    }
}
