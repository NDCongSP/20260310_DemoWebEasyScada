@page "/config"
@using Application.DTOs
@using Application.Interfaces.RestEase
@inject IConfigApi ConfigApi
@inject ISnackbar Snackbar
<PageTitle>Cấu hình</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4" GutterBottom="true">Cấu hình</MudText>

    @if (_loading)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
    }
    else if (_config != null)
    {
        <MudPaper Class="pa-4 mb-4" Elevation="2" Outlined="true">
            <MudText Typo="Typo.subtitle1" Class="mb-3">Thời gian reload (giây)</MudText>
            <MudNumericField @bind-Value="_reloadSeconds" Min="5" Max="120" Variant="Variant.Outlined" Immediate="true" Style="max-width: 120px" />
            <MudText Typo="Typo.caption" Class="mt-1">Trang Realtime sẽ tự cập nhật sau mỗi số giây này.</MudText>
        </MudPaper>

        <MudPaper Class="pa-4 mb-4" Elevation="2" Outlined="true">
            <MudText Typo="Typo.subtitle1" Class="mb-3">Địa điểm đo nhiệt độ</MudText>
            <MudTable Items="@(_config.Locations ?? new List<LocationConfigItemDto>())" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" Class="mb-4" Striped="true">
                <HeaderContent>
                    <MudTh>Tên địa điểm</MudTh>
                    <MudTh Style="width: 100px">Publish</MudTh>
                    <MudTh Style="width: 80px">Thao tác</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Tên">@(context.Name)</MudTd>
                    <MudTd DataLabel="Publish">
                        <MudSwitch T="bool" Value="context.Publish" ValueChanged="v => { context.Publish = v; StateHasChanged(); }" Color="Color.Primary" />
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoveLocation(context))" />
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <MudStack row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-2">
                <MudTextField @bind-Value="_newLocationName" Label="Tên địa điểm mới" Variant="Variant.Outlined" Style="max-width: 280px" Placeholder="VD: Khu lò A" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="AddLocation" StartIcon="@Icons.Material.Filled.Add">Thêm</MudButton>
            </MudStack>
        </MudPaper>

        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="Save" StartIcon="@Icons.Material.Filled.Save" Class="mb-4">Lưu cấu hình</MudButton>
    }
    else
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">Chưa có cấu hình. Tạo cấu hình mới.</MudAlert>
        <MudPaper Class="pa-4 mb-4" Outlined="true">
            <MudNumericField @bind-Value="_reloadSeconds" Label="Thời gian reload (giây)" Min="5" Max="120" Variant="Variant.Outlined" Class="mb-4" />
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateAndSave" StartIcon="@Icons.Material.Filled.Add">Tạo cấu hình mới</MudButton>
        </MudPaper>
    }
</MudContainer>

@code {
    private RevoConfigDto? _config;
    private bool _loading = true;
    private int _reloadSeconds = 10;
    private string _newLocationName = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _config = await ConfigApi.GetActiveAsync();
            if (_config != null)
                _reloadSeconds = _config.ReloadIntervalSeconds ?? 10;
            else
                _config = new RevoConfigDto { Locations = new List<LocationConfigItemDto>() };
        }
        finally
        {
            _loading = false;
        }
    }

    private void AddLocation()
    {
        if (string.IsNullOrWhiteSpace(_newLocationName)) return;
        _config ??= new RevoConfigDto { Locations = new List<LocationConfigItemDto>() };
        _config.Locations ??= new List<LocationConfigItemDto>();
        _config.Locations.Add(new LocationConfigItemDto { Id = Guid.NewGuid(), Name = _newLocationName.Trim(), Publish = true });
        _newLocationName = "";
    }

    private void RemoveLocation(LocationConfigItemDto item)
    {
        _config?.Locations?.Remove(item);
    }

    private async Task Save()
    {
        if (_config == null) return;
        _config.ReloadIntervalSeconds = _reloadSeconds;
        try
        {
            if (_config.Id == Guid.Empty)
                await ConfigApi.CreateAsync(_config);
            else
                await ConfigApi.UpdateAsync(_config.Id, _config);
            Snackbar.Add("Đã lưu cấu hình.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi: " + ex.Message, Severity.Error);
        }
    }

    private async Task CreateAndSave()
    {
        _config = new RevoConfigDto
        {
            Id = Guid.Empty,
            ReloadIntervalSeconds = _reloadSeconds,
            Actived = true,
            Locations = new List<LocationConfigItemDto>()
        };
        try
        {
            await ConfigApi.CreateAsync(_config);
            Snackbar.Add("Đã tạo cấu hình.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add("Lỗi: " + ex.Message, Severity.Error);
        }
    }
}
