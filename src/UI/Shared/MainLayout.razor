@inherits LayoutComponentBase
@using Radzen.Blazor

<RadzenLayout>
    <RadzenHeader>
        <RadzenSidebarToggle Click="ToggleDrawer" />
        <span class="rz-header-title">Realtime temperature</span>
    </RadzenHeader>
    <RadzenSidebar @bind-Expanded="_drawerOpen">
        <RadzenPanelMenu>
            <RadzenPanelMenuItem Text="Realtime" Path="/" Icon="thermostat" Match="NavLinkMatch.All" />
            <RadzenPanelMenuItem Text="Settings" Path="/config" Icon="settings" />
        </RadzenPanelMenu>
    </RadzenSidebar>
    <RadzenBody>
        <RadzenStack Gap="1rem" Style="padding: 1rem;">
            @Body
        </RadzenStack>
    </RadzenBody>
    <RadzenDialog />
    <RadzenNotification />
    <RadzenContextMenu />
    <RadzenTooltip />
</RadzenLayout>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
